# OpenRouter API key used for LLM and image model calls.
OPENROUTER_API_KEY=sk-or-...

# Base URL for the OpenRouter API.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional HTTP(S) proxy for outbound calls to model providers.
# Leave empty to rely on process-level HTTP_PROXY / HTTPS_PROXY env vars.
# Example: HTTP_PROXY=http://127.0.0.1:7890
HTTP_PROXY=

# Secret key used to sign and verify JWT access tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=must-be-set-in-env

# Secret for refresh tokens. If empty, falls back to JWT_SECRET.
# Use a separate value in production so access and refresh can be rotated independently.
JWT_REFRESH_SECRET=

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# Access token lifetime (seconds). Short-lived so revocation is frequent.
JWT_ACCESS_EXPIRES_SECONDS=900

# Refresh token lifetime (seconds). 7 days by default.
JWT_REFRESH_EXPIRES_SECONDS=604800

# Async PostgreSQL connection string for the application database.
DATABASE_URL=postgresql+asyncpg://mediaforge:mediaforge@localhost/mediaforge

# Redis connection string used for caching and task broker backends.
REDIS_URL=redis://localhost:6379/0

# Directory where generated assets and outputs are written.
OUTPUT_DIR=./outputs

# Object storage backend. "local" writes to OUTPUT_DIR and serves via /outputs/
# (default for dev). "s3" uploads to S3/MinIO/OSS/R2; requires `pip install -e .[s3]`.
STORAGE_BACKEND=local
# S3_ENDPOINT_URL=                # leave empty for AWS; MinIO e.g. http://minio:9000
# S3_BUCKET=mediaforge
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_BASE_URL=             # optional CDN/public URL prefix, e.g. https://cdn.example.com
# S3_FORCE_PATH_STYLE=true        # MinIO requires true; AWS prefers false

# Upload limits.
MAX_UPLOAD_SIZE=52428800
UPLOAD_URL_PREFIX=/outputs

# Max concurrent Gemini Pro image generation jobs (global across tenants).
SEMAPHORE_GEMINI_PRO_IMAGE=10

# Max concurrent GPT image generation jobs (global across tenants).
SEMAPHORE_GPT_IMAGE=15

# Max concurrent Veo video generation jobs (global across tenants).
SEMAPHORE_VEO=5

# Max concurrent Seedance video generation jobs (global across tenants).
SEMAPHORE_SEEDANCE=8

# Site metadata sent in OpenRouter HTTP headers.
SITE_URL=https://mediaforge.local
SITE_TITLE=MediaForge

# LangChain model used by the supervisor agent.
AGENT_MODEL=openai/gpt-4o-mini

# Image generation model API names.
IMAGE_MODEL_PRO=google/gemini-3-pro-image
IMAGE_MODEL_FAST=openai/gpt-5.4-image-2

# Video generation model API names.
VIDEO_MODEL_VEO=google/veo-3.1
VIDEO_MODEL_SEEDANCE=bytedance/seedance-2.0

# LangSmith observability (optional).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mediaforge
LANGSMITH_TRACING_V2=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Vector store backend: "chroma" (local dev) or "milvus" (production / Zilliz Cloud).
VECTOR_STORE_BACKEND=chroma
CHROMA_PERSIST_DIR=./chroma

# Milvus / Zilliz Cloud (required when VECTOR_STORE_BACKEND=milvus).
# For Zilliz Cloud: MILVUS_URI looks like https://xxx-xxxx.serverless.gcp-us-west1.cloud.zilliz.com
# MILVUS_TOKEN is the API key from Zilliz Cloud console.
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION=mediaforge

# DashScope (Alibaba Bailian) embedding models for RAG.
DASHSCOPE_API_KEY=
DASHSCOPE_TEXT_MODEL=text-embedding-v4
DASHSCOPE_TEXT_DIM=1024
DASHSCOPE_IMAGE_MODEL=qwen3-vl-embedding
DASHSCOPE_IMAGE_DIM=2560
DASHSCOPE_RERANK_MODEL=qwen3-vl-rerank

# Demo API keys for development/testing only (only effective when
# BACKCOMPAT_DEMO_KEYS=true). Replace with DB-issued API keys in production.
DEMO_KEY_STARTER=demo-key-starter
DEMO_KEY_PRO=demo-key-pro
DEMO_KEY_ENTERPRISE=demo-key-enterprise

# Auth cookie settings.
COOKIE_ACCESS_NAME=mf_access
COOKIE_REFRESH_NAME=mf_refresh
COOKIE_CSRF_NAME=mf_csrf
# Set to True in production when serving over HTTPS.
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=

# CSRF header the frontend echoes back.
CSRF_HEADER_NAME=X-CSRF-Token

# Password policy.
PASSWORD_MIN_LENGTH=8
PASSWORD_BCRYPT_ROUNDS=12

# Login lockout.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# Self-signup control. Empty = disabled (users created via script only).
# Set to a tenant_id to allow public signup into that tenant.
ALLOW_SELF_SIGNUP_TENANT_ID=

# CORS: comma-separated origins allowed to call the API with credentials.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Legacy X-Api-Key header against demo keys (P1/P2 dev convenience).
# Set to False once DB-issued API keys are rolled out.
BACKCOMPAT_DEMO_KEYS=true

# Logging (Loguru).
LOG_LEVEL=INFO
LOG_FORMAT=console
LOG_FILE=
LOG_ROTATION=50 MB
LOG_RETENTION=30 days
LOG_COMPRESSION=zip
